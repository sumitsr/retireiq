# RetireIQ Configuration

# Authentication Secret Key (Required)
JWT_SECRET_KEY=

# LLM Provider configuration (openai or azure_openai)
LLM_PROVIDER=azure_openai
LLM_MODEL_NAME=gpt-4o
LLM_TEMPERATURE=0.7

# OpenAI Credentials (if LLM_PROVIDER=openai)
OPENAI_API_KEY=

# Azure OpenAI Credentials (if LLM_PROVIDER=azure_openai)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2023-12-01-preview

# Lionis External Agent API Credentials
LIONIS_AGENT_TOKEN=
LIONIS_EVENT_TOKEN=

# Database Connection (e.g. postgresql://user:pass@localhost:5432/dbname)
# Leave blank to fallback to local SQLite (app.db)
DATABASE_URL=
