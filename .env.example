# RetireIQ Configuration

# Authentication Secret Key (Required - Application will fail if missing)
JWT_SECRET_KEY=YOUR_SECURE_JWT_SECRET

# Database Configuration (Used by Docker Compose)
POSTGRES_DB=retireiq_db
POSTGRES_USER=retireiq_user
POSTGRES_PASSWORD=YOUR_DB_PASSWORD

# LLM Provider configuration (ollama, openai, or azure_openai)
LLM_PROVIDER=ollama
LLM_MODEL_NAME=llama3
LLM_TEMPERATURE=0.7
OLLAMA_HOST=http://host.docker.internal:11434

# OpenAI Credentials (if LLM_PROVIDER=openai)
OPENAI_API_KEY=

# Azure OpenAI Credentials (if LLM_PROVIDER=azure_openai)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2023-12-01-preview

# Lionis External Agent API Credentials
LIONIS_AGENT_TOKEN=
LIONIS_EVENT_TOKEN=

# Database Connection (e.g. postgresql://user:pass@localhost:5432/dbname)
# Docker default: postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB:-retireiq_db}
DATABASE_URL=postgresql://retireiq_user:retireiq_pass@db:5432/retireiq_db

# --- Docker Orchestration (Optional Overrides) ---
# DB_IMAGE=ankane/pgvector:v0.5.1
# DB_CONTAINER_NAME=retireiq_db
# DB_PORT=5432
# APP_CONTAINER_NAME=retireiq_app
# APP_PORT=5000
# FLASK_APP=run.py
# FLASK_ENV=development
